{
  "name": "fitgirl-repacks-manager",
  "productName": "FitGirl Repacks Manager",
  "displayName": "FitGirl Repacks Manager",
  "companyName": "Alsasoft",
  "version": "0.1.0",
  "description": "FitGirl Repacks Manager",
  "author": "Alsasoft",
  "private": true,
  "main": "build/dist/index.js",
  "scripts": {
    "main:dev": "next dev",
    "build": "npm run build:next && (if exist build\\out (rmdir /s /q build\\out)) && mkdir build\\out && xcopy /e /q out build\\out\\ && rmdir /s /q out && npm run build:main",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "dev": "concurrently \"npm run main:dev\" \"tsc -p tsconfig.main.json -w\" \"wait-on build/dist/index.js && wait-on tcp:3000 && electron .\"",
    "scrape:full": "node scripts/scrape_full_site.js",
    "build:next": "next build",
    "build:main": "tsc -p tsconfig.main.json && node scripts/obfuscate.js",
    "build:exe": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.fitgirl-repacks-manager.app",
    "win": {
      "target": "nsis",
      "icon": "public/app_icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "FitGirl Repacks Manager - v${version}.${ext}"
    },
    "files": [
      {
        "from": "build/out",
        "to": "out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/dist",
        "to": "build/dist",
        "filter": [
          "**/*"
        ]
      },
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "build/release"
    },
    "npmRebuild": false,
    "asar": true,
    "artifactName": "FitGirl Repacks Manager - v${version}.${ext}",
    "electronFuses": {
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "runAsNode": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false
    }
  },
  "dependencies": {
    "@mantine/carousel": "8.3.18",
    "@mantine/core": "8.3.18",
    "@mantine/dates": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@mantine/notifications": "8.3.18",
    "@supabase/supabase-js": "^2.101.1",
    "@tabler/icons-react": "^3.40.0",
    "7zip-bin": "^5.2.0",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-serve": "^3.0.1",
    "embla-carousel-react": "^8.6.0",
    "fs-extra": "^11.2.0",
    "next": "^15.5.14",
    "next-electron-server": "^1.0.0",
    "node-unrar-js": "^2.0.2",
    "pocketbase": "^0.26.8",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.3.3",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "9.35.0",
    "javascript-obfuscator": "^5.3.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "5.9.2",
    "wait-on": "^9.0.4"
  },
  "packageManager": "yarn@4.13.0"
}
